import { getEffectiveSources } from "@/lib/sources";
import { mockMeta, pendingAccessMeta, notFound, fakeId } from "@/app/api/_util/meta";

export const dynamic = "force-dynamic";

// POST /api/sources/:key/run — вручную запустить прогон источника.
// Статус ответа зависит от РЕАЛЬНОГО статуса коннектора (getEffectiveSources):
// pending_access — честно сообщает, что доступа нет; источники с настоящей
// реализацией (сейчас — google_places) направляют на свой выделенный
// эндпоинт, где можно передать параметры реального запроса; остальные
// (status "mock"/"active" без своей реализации здесь) возвращают мок-успех,
// как и раньше.
export async function POST(_req: Request, { params }: { params: { key: string } }) {
  const source = getEffectiveSources().find((s) => s.key === params.key);
  if (!source) return notFound(`Источник с key="${params.key}" не найден в реестре lib/sources.ts.`);

  if (source.status === "pending_access") {
    return Response.json(
      {
        sourceKey: source.key,
        triggered: false,
        meta: pendingAccessMeta(
          `Источник "${source.name}" ждёт доступа к внешнему API и не может быть запущен реально.`,
          source.required_env_vars
        ),
      },
      { status: 202 }
    );
  }

  if (source.key === "google_places") {
    return Response.json(
      {
        sourceKey: source.key,
        triggered: false,
        redirectTo: "/api/connectors/google-places",
        meta: mockMeta(
          "У этого источника есть настоящая реализация — вызовите POST /api/connectors/google-places с телом {query, city} вместо этого общего эндпоинта, чтобы выполнить реальный поиск."
        ),
      },
      { status: 409 }
    );
  }

  return Response.json({
    sourceKey: source.key,
    triggered: true,
    runId: fakeId("RUN"),
    newSignalsCountMock: Math.floor(Math.random() * 10),
    meta: mockMeta(
      `Запуск источника "${source.name}" — заглушка. Реальный прогон сбора сигналов не выполняется. В проде это поставит задачу воркеру коннектора и обновит sources.last_run_at / source_health_log.`
    ),
  });
}
